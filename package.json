{
  "name": "openacp",
  "version": "0.6.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "bin": {
    "openacp": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc && mkdir -p dist/data && cp src/data/registry-snapshot.json dist/data/",
    "build:publish": "tsx scripts/build-publish.ts",
    "dev": "tsc --watch",
    "dev:loop": "./scripts/dev-loop.sh",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "homepage": "https://github.com/Open-ACP/OpenACP",
  "repository": {
    "type": "git",
    "url": "https://github.com/Open-ACP/OpenACP"
  },
  "packageManager": "pnpm@10.5.0",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.16.0",
    "@hono/node-server": "^1.19.11",
    "@inquirer/prompts": "^8.3.2",
    "@zed-industries/claude-agent-acp": "^0.22.2",
    "diff": "^8.0.3",
    "discord.js": "^14.25.1",
    "fastest-levenshtein": "^1.0.16",
    "grammy": "^1.41.1",
    "hono": "^4.12.8",
    "nanoid": "^5.0.0",
    "node-wav": "^0.0.2",
    "ogg-opus-decoder": "^1.7.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "pino-roll": "^4.0.0",
    "shiki": "^4.0.2",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@rolldown/binding-darwin-arm64": "1.0.0-rc.10",
    "@types/diff": "^8.0.0",
    "@types/node": "^25.5.0",
    "husky": "^9.1.7",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  }
}
