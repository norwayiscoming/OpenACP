    "nanoid": "^5.0.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "pino-roll": "^4.0.0",
    "shiki": "^4.0.2",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@rolldown/binding-darwin-arm64": "1.0.0-rc.10",
