{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "declaration": true,
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "@openacp/cli/testing": ["../../dist/testing.d.ts"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/**/__tests__/**"]
}
